    "widget_expensive_desc": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "En yüksek tutarlı aboneliklerinizi listeler."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lists your most expensive subscriptions."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Ən yüksək məbləğli abunəliklərinizi sadalayır."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Listet Ihre teuersten Abonnements auf."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enumera tus suscripciones más caras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Liste vos abonnements les plus chers."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mencantumkan langganan Anda yang paling mahal."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ең қымбат жазылымдарыңызды тізімдейді."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Эң кымбат жазылууларыңызды тизмелейт."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Список ваших самых дорогих подписок."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "translated",
            "value": "Iň gymmat abunalyklaryňyzy sanawa alýar."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Eng qimmat obunalaringiz ro’yxatini ko’rsatadi."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "列出您最昂贵的订阅。"
          }
        }
      }
    },
