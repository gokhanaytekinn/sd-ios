    "widget_quick_add_desc": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tek dokunuşla yeni abonelik ekleyin."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a new subscription with a single tap."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Tək toxunuşla yeni abunəlik əlavə edin."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie mit einem Fingertipp ein neues Abonnement hinzu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade una nueva suscripción con un solo toque."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un nouvel abonnement d'un seul geste."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan langganan baru dengan satu ketukan."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Бір тию арқылы жаңа жазылымды қосыңыз."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Бир тийүү менен жаңы жазылууну кошуңуз."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте новую подписку одним нажатием."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir basmak bilen täze abunalyk goşuň."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir marta bosish orqali yangi obunani qo’shing."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "只需点击一下即可添加新订阅。"
          }
        }
      }
    },
    "widget_upcoming_title": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yaklaşan Ödemeler"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Upcoming Payments"
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Gələcək Ödənişlər"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anstehende Zahlungen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Próximos pagos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Paiements à venir"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembayaran Mendatang"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Жақын арадағы төлемдер"
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Жакынкы төлөмдөр"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предстоящие платежи"
          }
        },
        "tk": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelejekki tölegler"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Kelgusi to’lovlar"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "即将到来"
          }
        }
      }
    },
    "widget_upcoming_desc": {
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelecek 10 gün içindeki ödemelerinizi gösterir."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows your payments due in the next 10 days."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Növbəti 10 gün üçün ödənişlərinizi göstərir."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt Ihre in den nächsten 10 Tagen fälligen Zahlungen an."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra tus pagos vencidos en los próximos 10 días."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche vos paiements dus dans les 10 prochains jours."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menampilkan pembayaran Anda yang jatuh tempo dalam 10 hari ko depan."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Алдағы 10 күндегі төлемдеріңізді көрсетеді."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Алдағы 10 күндөгү төлөмдөрүңүздү көрсөтөт."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показывает ваши платежи, подлежащие оплате в ближайшие 10 дней."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "translated",
            "value": "Indiki 10 günüň dowamynda töleneriňizi görkezýär."
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Keyingi 10 kun ichidagi to’lovlarni ko’rsatadi."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "显示您在接下来的 10 天内到期的付款。"
          }
        }
      }
    },
