"faq_q1" = "Abunəlik necə ləğv edilir?";
"faq_a1" = "Abunəlik detalları səhifəsinə daxil olaraq ən aşağıda yerləşən 'Abunəliyi Ləğv et' düyməsinə klikləyə bilərsiniz. Bu əməliyyat yalnız proqram daxili izləməni dayandırır, servis təminatçısı tərəfindən də ləğv etməyi unutmayın.";
"faq_q2" = "Məlumatlarım təhlükəsizdirmi?";
"faq_a2" = "Bəli, bütün məlumatlarınız cihazınızda şifrələnmiş şəkildə saxlanılır. Sub Tracker, şəxsi məlumatlarınızı üçüncü tərəflərlə paylaşmır.";
"faq_q3" = "Banka hesabımı necə bağlayaram?";
"faq_a3" = "Hazırda birbaşa bank inteqrasiyası əvəzinə, SMS və bildiriş oxuma icazəsi ilə avtomatik izləmə təmin edirik. Bank inteqrasiyası yaxında gələcək.";
"faq_q4" = "Pul iadəsi ala bilərəmmi?";
"faq_a4" = "Proqram daxili satınalmalarda Google Play/App Store siyasətləri keçərlidir. İadə tələblərinizi aidiyyatı mağaza üzərindən edə bilərsiniz.";
"faq_q5" = "Xatırladıcılar işləmir, nə etməliyəm?";
"faq_a5" = "Cihaz ayarlarından proqramın bildiriş icazələrinin açıq olduğundan əmin olun. Həmçinin batareya qənaət rejiminin bildirişləri əngəlləmədiyini yoxlayın.";
"faq_q6" = "Şübhəli əməliyyat bildirimi nədir?";
"faq_a6" = "Proqram, normal xərc rejiminizdən kənar və ya naməlum ödənişləri aşkar etdikdə sizi xəbərdar edir. Bu əməliyyatları 'Şübhəli Əməliyyatlar' ekranından araşdıra bilərsiniz.";
"privacy_policy_title" = "Məxfilik Siyasəti";
"privacy_last_updated" = "Son Yenilənmə: 20 Fevral 2026";
"privacy_title_1" = "1. Giriş";
"privacy_content_1" = "Sub Tracker (\"Proqram\") olaraq məxfiliyinizə önəm veririk. Bu Məxfilik Siyasəti, proqramımızdan istifadə edərkən məlumatlarınızın necə toplandığını, istifadə edildiyini və qorunduğunu izah edir.";
"privacy_title_2" = "2. Toplanan Məlumatlar";
"privacy_content_2" = "Proqramımız sizə daha yaxşı xidmət göstərmək üçün aşağıdakı məlumatları toplaya və ya emal edə bilər:\n\n• Abunəlik Məlumatları: Əlavə etdiyiniz abunəliklərin adı, qiyməti, ödəniş tarixləri.\n• İstifadə Məlumatları: Proqram daxili qarşılıqlı əlaqələr və seçimlər.\n• Cihaz Məlumatları: Proqramın işləməsi üçün lazım olan əsas cihaz identifikatorları.";
"privacy_title_3" = "3. Məlumatlardan İstifadə";
"privacy_content_3" = "Toplanan məlumatlar yalnız aşağıdakı məqsədlərlə istifadə olunur:\n\n• Abunəliklərinizi izləməyinizi təmin etmək.\n• Ödəniş günü yaxınlaşan abunəliklər üçün xatırlatıcı bildirişləri göndərmək.\n• Proqram performansını yaxşılaşdırmaq və xətaları aradan qaldırmaq.";
"privacy_title_4" = "4. Məlumat Təhlükəsizliyi";
