"faq_q1" = "Abonelik nasıl iptal edilir?";
"faq_a1" = "Abonelik detay sayfasına giderek en altta bulunan 'Aboneliği İptal Et' butonuna tıklayabilirsiniz. Bu işlem sadece uygulama içi takibi sonlandırır, servis sağlayıcı üzerinden de iptal etmeyi unutmayın.";
"faq_q2" = "Verilerim güvende mi?";
"faq_a2" = "Evet, tüm verileriniz cihazınızda şifrelenmiş olarak saklanır. Sub Tracker, kişisel verilerinizi üçüncü taraflarla paylaşmaz.";
"faq_q3" = "Banka hesabımı nasıl bağlarım?";
"faq_a3" = "Uygulamamız şu an için manuel girişleri desteklemektedir. Banka ve SMS tarama özellikleri güvenlik nedeniyle kaldırılmıştır.";
"faq_q4" = "Para iadesi alabilir miyim?";
"faq_a4" = "Uygulama içi satın alımlarda Google Play/App Store politikaları geçerlidir. İade taleplerinizi ilgili mağaza üzerinden yapabilirsiniz.";
"faq_q5" = "Hatırlatıcılar çalışmıyor, ne yapmalıyım?";
"faq_a5" = "Cihaz ayarlarından uygulamanın bildirim izinlerinin açık olduğundan emin olun. Ayrıca pil tasarrufu modunun bildirimleri engellemediğini kontrol edin.";
"faq_q6" = "Şüpheli işlem bildirimi nedir?";
"faq_a6" = "Uygulama, normal harcama kalıplarınızın dışındaki ödemeleri veya tanımlanamayan masrafları tespit ettiğinde sizi uyarır. Bu işlemleri 'Şüpheli İşlemler' ekranından inceleyebilirsiniz.";
"privacy_policy_title" = "Gizlilik Politikası";
"privacy_last_updated" = "Son Güncelleme: 20 Şubat 2026";
"privacy_title_1" = "1. Giriş";
"privacy_content_1" = "Sub Tracker (\"Uygulama\") olarak gizliliğinize önem veriyoruz. Bu Gizlilik Politikası, uygulamamızı kullanırken verilerinizin nasıl toplandığını, kullanıldığını ve korunduğunu açıklar.";
"privacy_title_2" = "2. Toplanan Veriler";
"privacy_content_2" = "Uygulamamız, size daha iyi hizmet verebilmek için aşağıdaki verileri toplayabilir veya işleyebilir:\n\n• Abonelik Bilgileri: Eklediğiniz aboneliklerin adı, fiyatı, ödeme tarihleri.\n• Kullanım Verileri: Uygulama içi etkileşimler ve tercihler.\n• Cihaz Bilgileri: Uygulamanın çalışması için gerekli temel cihaz tanımlayıcıları.";
"privacy_title_3" = "3. Verilerin Kullanımı";
"privacy_content_3" = "Toplanan veriler yalnızca aşağıdaki amaçlarla kullanılır:\n\n• Aboneliklerinizi takip etmenizi sağlamak.\n• Ödeme günü yaklaşan abonelikler için hatırlatıcı bildirimleri göndermek.\n• Uygulama performansını iyileştirmek ve hataları gidermek.";
"privacy_title_4" = "4. Veri Güvenliği";
"privacy_content_4" = "Kişisel verileriniz cihazınızda güvenli bir şekilde saklanır. Sunucularımızda tutulan veriler (hesap oluşturmanız durumunda) endüstri standardı şifreleme yöntemleri ile korunur. Verileriniz asla izniniz olmaksızın üçüncü taraflara satılmaz veya paylaşılmaz.";
"privacy_title_5" = "5. İzinler";
"privacy_content_5" = "Uygulama, size bildirim gönderebilmek için bildirim izni talep edebilir. Bu izin, yalnızca abonelik hatırlatıcıları için kullanılır.";
"privacy_title_6" = "6. İletişim";
"privacy_content_6" = "Gizlilik politikamızla ilgili sorularınız için bizimle iletişime geçebilirsiniz:\ngokhanaytekinn@yandex.com";
