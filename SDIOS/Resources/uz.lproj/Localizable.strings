"faq_q1" = "Obunani qanday bekor qilish mumkin?";
"faq_a1" = "Obuna sahifasiga kirib, eng pastdagi 'Obunani bekor qilish' tugmasini bosing. Bu faqat ilovadagi kuzatishni toʻxtatadi, xizmat koʻrsatuvchi orqali ham bekor qilishni unutmang.";
"faq_q2" = "Maʼlumotlarim xavfsizimi?";
"faq_a2" = "Ha, barcha maʼlumotlar qurilmangizda shifrlangan holatda saqlanadi. Biz maʼlumotlaringizni uchinchi shaxslarga bermaymiz.";
"faq_q3" = "Bank kartasini qanday ulash mumkin?";
"faq_a3" = "Hozirda SMS va bildirishnomalarni oʻqish orqali avtomatik kuzatish amalga oshiriladi. Bank integratsiyasi yaqin orada qoʻshiladi.";
"faq_q4" = "Toʻlovni qaytarib olsam boʻladimi?";
"faq_a4" = "Ilova ichidagi xaridlar boʻyicha Google Play/App Store qoidalari amal qiladi. Savollar boʻyicha rasmiy doʻkonlarga murojaat qilishingiz mumkin.";
"faq_q5" = "Eslatmalar ishlamayapti, nima qilish kerak?";
"faq_a5" = "Sozlamalardan bildirishnomalar yoqilganligini tekshiring. Shuningdek, quvvat tejash rejimi bunga toʻsqinlik qilmayotganiga ishonch hosil qiling.";
"faq_q6" = "Shubhali tranzaksiya nima?";
"faq_a6" = "Ilova gʻayritabiiy yoki nomaʼlum xarajatlarni sezsa, sizni ogohlantiradi. Bu tranzaksiyalarni 'Shubhali toʻlovlar' sahifasida koʻrishingiz mumkin.";
