"privacy_policy_title" = "隐私政策";
"privacy_last_updated" = "最后更新日期：2026年2月20日";
"privacy_title_1" = "1. 简介";
"privacy_content_1" = "作为订阅追踪器（“本应用”），我们重视您的隐私。本隐私政策解释了在使用我们的应用程序时如何收集、使用和保护您的数据。";
"privacy_title_2" = "2. 收集的数据";
"privacy_content_2" = "我们的应用程序可能会收集或处理以下数据，以便为您提供更好的服务：\n\n• 订阅信息：您添加的订阅的名称、价格和扣费日期。\n• 使用数据：应用内交互和偏好。\n• 设备信息：应用程序运行所需的基本设备标识符。";
"privacy_title_3" = "3. 数据使用";
"privacy_content_3" = "收集的数据仅用于以下目的：\n\n• 让您能够追踪您的订阅。\n• 为接下来的扣费日期发送提醒通知。\n• 改进应用性能并修复错误。";
"privacy_title_4" = "4. 数据安全";
"privacy_content_4" = "您的个人数据安全地存储在您的设备上。存储在我们服务器上的数据（如果您创建了账户）受行业标准加密方法的保护。未经您的许可，您的数据绝不会被出售或与第三方分享。";
"privacy_title_5" = "5. 权限";
"privacy_content_5" = "应用程序可能会请求通知权限以向您发送通知。此权限仅用于订阅提醒。";
"privacy_title_6" = "6. 联系方式";
"privacy_content_6" = "有关我们隐私政策的问题，您可以通过以下方式联系我们：\ngokhanaytekinn@yandex.com";
