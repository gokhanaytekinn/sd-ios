"faq_q1" = "How to cancel a subscription?";
"faq_a1" = "Go to the subscription details page and click 'Cancel Subscription' at the bottom. This action only ends the tracking within the app.";
"faq_q2" = "Is my data secure?";
"faq_a2" = "Yes, all your data is stored encrypted. Sub Tracker does not share your personal data with third parties.";
"faq_q3" = "How do I connect my bank account?";
"faq_a3" = "Our application currently supports manual entries. Bank scanning features have been removed for security reasons.";
"faq_q4" = "Can I get a refund?";
"faq_a4" = "App Store policies apply to in-app purchases. You can make your refund requests through the App Store.";
"faq_q5" = "Reminders are not working, what should I do?";
"faq_a5" = "Make sure the app's notification permissions are enabled in Settings. Also, check that battery saver mode is not blocking notifications.";
"faq_q6" = "What is a suspicious transaction notification?";
"faq_a6" = "The app warns you when it detects payments outside your normal spending patterns. You can review these on the 'Suspicious Transactions' screen.";

